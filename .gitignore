# OS files
.DS_Store
Thumbbs.db
desktop.ini

# Editor directories
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Logs
*.log
npm-debug.log*

# node_modules — but KEEP lock files (GitHub Actions and Render need them)
node_modules/
dist/
build/
!package-lock.json
!backend/package-lock.json

# Environment files — never commit secrets
.env
.env.local

# Temporary files
*.tmp
*.bak
*.swp

# Backend runtime files
backend/node_modules/
backend/db/*.db
backend/.env
backend/uploads/*
!backend/uploads/.gitkeep
