# ============================================================
# Sangguniang Bayan of Claveria — Backend Environment Config
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Secrets — change these to any long random strings
SESSION_SECRET=change_this_to_a_long_random_secret_string_at_least_64_characters
JWT_SECRET=another_long_random_secret_string_for_jwt_tokens_here

# GitHub OAuth App
# Create at: https://github.com/settings/developers -> OAuth Apps
# IMPORTANT — set these EXACT values in your GitHub OAuth App:
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# GitHub Repository (where ordinances get published as Markdown)
GITHUB_REPO_OWNER=your_github_username_or_org
GITHUB_REPO_NAME=sangguniang-bayan-claveria
GITHUB_REPO_BRANCH=main

# Who gets admin/staff roles (GitHub usernames, comma-separated)
ADMIN_GITHUB_USERS=your_github_username
STAFF_GITHUB_USERS=staff_user1,staff_user2

# Frontend URL — backend now serves frontend too, both on same port
FRONTEND_URL=http://localhost:3000
