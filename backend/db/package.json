{
  "name": "sb-claveria-backend",
  "version": "1.0.0",
  "description": "Backend API for the Sangguniang Bayan of Claveria, Masbate",
  "main": "server.js",
  "scripts": {
    "start":       "node server.js",
    "start:fresh": "node db/init.js && node db/seed.js && node server.js",
    "dev":         "nodemon server.js",
    "init-db":     "node db/init.js",
    "seed":        "node db/seed.js",
    "test":        "node tests/run.js",
    "build":       "echo No build step required"
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "compression":        "^1.7.4",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-session":    "^1.18.0",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.2",
    "multer":             "^1.4.5-lts.1",
    "pg":                 "^8.11.5",
    "sql.js":             "^1.14.1",
    "uuid":               "^9.0.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
